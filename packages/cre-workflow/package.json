{
  "name": "@regreportcre/cre-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "simulate": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/simulate.ts",
    "simulate:anomaly": "FORCE_ANOMALY=true NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/simulate.ts",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "mock-custodian": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/mocks/custodian-server.ts"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.1.2",
    "@google/generative-ai": "^0.1.3",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}